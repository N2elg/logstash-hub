<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %c{1} - %msg%n</Property>
        <Property name="APP_LOG_LEVEL">INFO</Property>
        <Property name="SERVICE_LOG_NAME">WARN</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}" />
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="org.n2elg.log" level="${APP_LOG_LEVEL}" additivity="false">
            <AppenderRef ref="Console" />
        </Logger>

        <Root level="${SERVICE_LOG_NAME}">
            <AppenderRef ref="Console" />
        </Root>
    </Loggers>
</Configuration>